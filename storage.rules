rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to validate file size (max 10MB)
    function isValidSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }
    
    // Helper function to validate image file types
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // Helper function to validate document file types
    function isValidDocumentType() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/vnd.ms-excel') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    }
    
    // Company logos - authenticated users can upload
    match /company-logos/{fileName} {
      allow read: if true; // Public read for logos
      allow write: if isSignedIn() && isValidImageType() && isValidSize();
    }
    
    // Invoice attachments - authenticated users only
    match /invoices/{invoiceId}/{fileName} {
      allow read, write: if isSignedIn() && isValidSize() && 
        (isValidImageType() || isValidDocumentType());
    }
    
    // Challan attachments - authenticated users only
    match /challans/{challanId}/{fileName} {
      allow read, write: if isSignedIn() && isValidSize() && 
        (isValidImageType() || isValidDocumentType());
    }
    
    // Customer documents - authenticated users only
    match /customers/{customerId}/{fileName} {
      allow read, write: if isSignedIn() && isValidSize();
    }
    
    // Template assets - authenticated users only
    match /templates/{templateId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidImageType() && isValidSize();
    }
    
    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
